    "@valon-technologies/gestalt": "^0.0.1-alpha.84",
    "@valon-technologies/gestalt-web": "^0.0.1-alpha.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "oxlint": "1.74.0",
    "postcss": "8.5.9",
