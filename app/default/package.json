{
  "name": "@gestalt/app-default",
  "version": "0.0.1-alpha.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:theme": "node --env-file-if-exists=.env.local scripts/dev-theme-watch.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
