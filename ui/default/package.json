{
  "name": "@gestalt/ui-default",
  "version": "0.0.2-alpha.2",
  "private": true,
  "scripts": {
    "dev": "./dev.sh",
    "dev:next": "next dev",
    "dev:theme": "node --env-file-if-exists=.env.local scripts/dev-theme-watch.mjs",
    "build": "next build && npm run build:admin-static",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "build:admin-static": "tsx src/admin-static-assets.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@shikijs/langs": "^3.23.0",
    "@shikijs/themes": "^3.23.0",
    "next": "^16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "postcss": "8.5.9",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.20.6",
    "typescript": "6.0.2"
  }
}
