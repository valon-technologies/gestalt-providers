{
  "name": "@gestalt/agent-cursor",
  "version": "0.0.1-alpha.1",
  "description": "Gestalt agent provider backed by the Cursor Agent SDK",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test --max-concurrency 1",
    "check": "bun run typecheck && bun test --max-concurrency 1"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@connectrpc/connect": "2.1.0",
    "@connectrpc/connect-node": "2.1.0",
    "@cursor/sdk": "1.0.11",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@valon-technologies/gestalt": "0.0.1-alpha.43",
    "ajv": "8.20.0",
    "sqlite3": "file:./stubs/sqlite3"
  },
  "overrides": {
    "sqlite3": "file:./stubs/sqlite3"
  },
  "devDependencies": {
    "@types/bun": "1.3.2",
    "typescript": "5.9.3"
  },
  "gestalt": {
    "provider": {
      "kind": "agent",
      "target": "./src/provider.ts#provider"
    }
  }
}
